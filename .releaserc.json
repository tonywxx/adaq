{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/semantic-release-prepare.mjs ${nextRelease.version} ${nextRelease.gitTag}"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "package.json",
          "pnpm-lock.yaml",
          "src-tauri/Cargo.lock",
          "src-tauri/Cargo.toml",
          "src-tauri/tauri.conf.json",
          "release/latest.json"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "release/latest.json",
            "label": "Tauri updater manifest"
          },
          {
            "path": "src-tauri/target/release/bundle/**/*.sig"
          },
          {
            "path": "src-tauri/target/release/bundle/**/*.{tar.gz,zip}"
          },
          {
            "path": "src-tauri/target/release/bundle/**/*.{dmg,AppImage,deb,rpm,msi,exe}"
          }
        ]
      }
    ]
  ]
}
