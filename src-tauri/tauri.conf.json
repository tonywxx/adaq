{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "adaq",
	"version": "0.5.0",
	"identifier": "bid.adaq.desktop",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "AdaQ",
				"width": 1280,
				"height": 860,
				"minWidth": 800,
				"minHeight": 600,
				"resizable": true,
				"center": true,
				"hiddenTitle": true,
				"titleBarStyle": "Overlay",
				"trafficLightPosition": {
					"x": 16,
					"y": 26
				}
			}
		],
		"trayIcon": {
			"iconPath": "icons/128x128.png",
			"iconAsTemplate": false,
			"id": "adaq-tray"
		},
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"createUpdaterArtifacts": true,
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1REI5QzgxNTcwODFFNzEKUldSeEhnaFhnWnpiMVJuSDQveC85OWMveEtqYllhYWZsU0I1TGdHcjBEWWhUS2VkUnZaUC91YW4K",
			"endpoints": [
				"https://github.com/tonywxx/adaq/releases/latest/download/latest.json"
			]
		}
	}
}
