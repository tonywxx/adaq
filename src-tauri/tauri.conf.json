{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "adaq",
	"version": "0.1.0",
	"identifier": "bid.adaq.desktop",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"width": 1280,
				"height": 860,
				"minWidth": 800,
				"minHeight": 600,
				"center": true,
				"hiddenTitle": true,
				"titleBarStyle": "Overlay",
				"trafficLightPosition": {
					"x": 16,
					"y": 26
				}
			}
		],
		"trayIcon": {
			"iconPath": "icons/128x128.png",
			"iconAsTemplate": false,
			"id": "adaq-tray"
		},

		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
